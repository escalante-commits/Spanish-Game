{sp:'planear',en:'to plan',forms:['planeo','planeas','planea','planeamos','planean'],sentences:[['I’m planning a trip.','Estoy planeando un viaje.'],['Let’s plan the party.','Vamos a planear la fiesta.']]},
{sp:'llenar',en:'to fill',forms:['lleno','llenas','llena','llenamos','llenan'],sentences:[['Fill the tank, please.','Llena el tanque, por favor.'],['I’m going to fill my water bottle.','Voy a llenar mi botella de agua.']]},
{sp:'mudar',en:'to move away',forms:['mudo','mudas','muda','mudamos','mudan'],sentences:[['We’re going to move soon.','Nos vamos a mudar pronto.'],['They moved to another city.','Se mudaron a otra ciudad.']]},
{sp:'investigar',en:'to research; investigate',forms:['investigo','investigas','investiga','investigamos','investigan'],sentences:[['I’m going to research more.','Voy a investigar más.'],['The police investigate the case.','La policía investiga el caso.']]},
{sp:'crecer',en:'to grow up',forms:['crezco','creces','crece','crecemos','crecen'],sentences:[['I grew up in California.','Crecí en California.'],['Kids grow fast.','Los niños crecen rápido.']]},
{sp:'recoger',en:'to pick up',forms:['recojo','recoges','recoge','recogemos','recogen'],sentences:[['I’m going to pick up the food.','Voy a recoger la comida.'],['Can you pick me up?','¿Puedes recogerme?']]},
{sp:'comprar',en:'to buy',forms:['compro','compras','compra','compramos','compran'],sentences:[['I’m going to buy milk.','Voy a comprar leche.'],['What did you buy?','¿Qué compraste?']]},
{sp:'trabajar',en:'to work',forms:['trabajo','trabajas','trabaja','trabajamos','trabajan'],sentences:[['I have to work tomorrow.','Tengo que trabajar mañana.'],['Where do you work?','¿Dónde trabajas?']]},
{sp:'dormir',en:'to sleep',forms:['duermo','duermes','duerme','dormimos','duermen'],sentences:[['I want to sleep more.','Quiero dormir más.'],['Did you sleep well?','¿Dormiste bien?']]},
{sp:'ayudar',en:'to help',forms:['ayudo','ayudas','ayuda','ayudamos','ayudan'],sentences:[['I can help you.','Te puedo ayudar.'],['Help me, please.','Ayúdame, por favor.']]},
{sp:'esperar',en:'to wait; hope',forms:['espero','esperas','espera','esperamos','esperan'],sentences:[['Wait for me a little.','Espérame tantito.'],['I hope everything goes well.','Espero que todo salga bien.']]},
{sp:'manejar',en:'to drive',forms:['manejo','manejas','maneja','manejamos','manejan'],sentences:[['I’ll drive.','Yo manejo.'],['Can you drive at night?','¿Puedes manejar de noche?']]},
{sp:'comer',en:'to eat',forms:['como','comes','come','comemos','comen'],sentences:[['Did you eat yet?','¿Ya comiste?'],['I’m going to eat tacos.','Voy a comer tacos.']]},
{sp:'pedir',en:'to ask for; order',forms:['pido','pides','pide','pedimos','piden'],sentences:[['I’m going to order tacos.','Voy a pedir tacos.'],['Ask for help.','Pide ayuda.']]},
{sp:'cuidar',en:'to care for; watch',forms:['cuido','cuidas','cuida','cuidamos','cuidan'],sentences:[['I’m going to take care of the baby.','Voy a cuidar al bebé.'],['Take care of yourself.','Cuídate.']]},
{sp:'jugar',en:'to play',forms:['juego','juegas','juega','jugamos','juegan'],sentences:[['The dog wants to play.','El perro quiere jugar.'],['Do you play soccer?','¿Juegas fútbol?']]},
{sp:'necesitar',en:'to need',forms:['necesito','necesitas','necesita','necesitamos','necesitan'],sentences:[['I need water.','Necesito agua.'],['Do you need help?','¿Necesitas ayuda?']]}
];
const topics={
'Tacos / food':['comer','querer','tomar','pagar','pedir','servir','traer','gustar','necesitar'],
'At home':['limpiar','lavar','bañar','descansar','dormir','despertar','abrir','timbrar','hacer'],
'Errands':['ir','llevar','traer','comprar','recoger','pagar','buscar','llegar','manejar'],
'Relationship / feelings':['sentir','querer','pelear','hablar','decir','pensar','recordar','reír'],
'Travel / plans':['viajar','volar','planear','visitar','llegar','salir','regresar','decidir'],
'Pets / baby':['adoptar','acoger','bañar','cuidar','llevar','recoger','querer','jugar','despertar']
};
let store=JSON.parse(localStorage.getItem('verbQuestMX')||'{}');
store.stats ||= {}; store.xp ||=0; store.streak ||=0; store.lastDaily ||=''; store.sessions ||=0; store.history ||=[]; save();
let mode='home', current=null, daily=[], dailyIdx=0, dailyResults=[], lastSpanish='', voices=[];
const $=id=>document.getElementById(id); const todayKey=()=>new Date().toDateString();
function save(){localStorage.setItem('verbQuestMX',JSON.stringify(store));}
function norm(s){return (s||'').toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[¿?¡!.,]/g,'').replace(/\s+/g,' ')}
function shuffle(a){return [...a].sort(()=>Math.random()-0.5)}
function accentButtons(id){return `<div class="accentbar"><span class="small muted">Accents:</span> ${['á','é','í','ó','ú','ü','ñ','¿','¡'].map(ch=>`<button type="button" onclick="insertAccent('${id}','${ch}')">${ch}</button>`).join('')}</div>`}
function insertAccent(id,ch){const el=$(id); if(!el)return; const s=el.selectionStart??el.value.length,e=el.selectionEnd??el.value.length; el.value=el.value.slice(0,s)+ch+el.value.slice(e); el.focus(); el.selectionStart=el.selectionEnd=s+ch.length;}
function pickVoice(){voices=speechSynthesis.getVoices(); const v=voices.find(v=>v.lang.toLowerCase()==='es-mx')||voices.find(v=>v.lang.toLowerCase().startsWith('es-mx'))||voices.find(v=>v.lang.toLowerCase().startsWith('es')); $('voiceStatus').textContent=v?`${v.name} (${v.lang})`:'No Spanish voice found yet'; return v;}
if('speechSynthesis' in window){speechSynthesis.onvoiceschanged=pickVoice; setTimeout(pickVoice,250)} else {$('voiceStatus').textContent='not supported'}
function speak(text){if(!('speechSynthesis' in window)||!text)return; speechSynthesis.cancel(); const u=new SpeechSynthesisUtterance(text); const v=pickVoice(); if(v)u.voice=v; u.lang=v?.lang||'es-MX'; u.rate=.86; speechSynthesis.speak(u); lastSpanish=text;}
function stat(v){store.stats[v.sp] ||= {seen:0,correct:0,wrong:0,streak:0,next:0,last:0}; return store.stats[v.sp];}
function mastery(v){const s=stat(v); return Math.min(5, Math.floor((s.correct + s.streak)/2));}
function dueScore(v){const s=stat(v), now=Date.now(); let due = now >= (s.next||0) ? 50 : 0; return due + Math.max(0,20-s.correct*2)+s.wrong*6 + Math.random()*12;}
function chooseDaily(){return shuffle(verbs).sort((a,b)=>dueScore(b)-dueScore(a)).slice(0,10).map(v=>{const pair=shuffle(v.sentences)[0]; return {verb:v.sp,en:v.en,prompt:pair[0],answer:pair[1],hint:v.sp,forms:v.forms};});}
function isCorrect(user, answer){const a=norm(user), b=norm(answer); if(!a)return false; if(a===b || a.includes(b) || b.includes(a))return true; const aw=a.split(' '), bw=b.split(' '); const overlap=aw.filter(w=>bw.includes(w)).length; return aw.length>=2 && overlap>=Math.min(3,bw.length);}
function updateVerb(vsp, ok){const v=verbs.find(x=>x.sp===vsp); const s=stat(v); s.seen++; s.last=Date.now(); if(ok){s.correct++; s.streak++; store.xp+=10; const days=[1,2,4,7,14,30][Math.min(s.streak,5)]||30; s.next=Date.now()+days*86400000;} else {s.wrong++; s.streak=0; store.xp+=2; s.next=Date.now()+3600000;} save();}
function dashboardStats(){let mastered=verbs.filter(v=>mastery(v)>=4).length; let due=verbs.filter(v=>Date.now()>stat(v).next).length; return {mastered,due,total:verbs.length,xp:store.xp||0,streak:store.streak||0};}
function go(m){mode=m; if(m==='home')renderHome(); if(m==='flash')renderFlash(); if(m==='situations')renderSituation(); if(m==='chat')renderChatSetup(); if(m==='bank')renderBank();}
function renderHome(){const d=dashboardStats(); $('main').innerHTML=`<section class="grid"><div class="stat"><span class="tag">XP</span><br><b>${d.xp}</b></div><div class="stat"><span class="tag">Daily streak</span><br><b>${d.streak}</b></div><div class="stat"><span class="tag">Mastered verbs</span><br><b>${d.mastered}/${d.total}</b></div><div class="stat"><span class="tag">Due now</span><br><b>${d.due}</b></div></section><section class="card"><h2>Today’s best move</h2><p>Do your <b>Daily 10</b>. It chooses verbs you’re due to review, verbs you’ve missed, and some new ones so it changes each time without becoming random chaos.</p><button onclick="startDaily()">Start Daily 10</button><button class="light" onclick="go('chat')">Practice a conversation</button></section><section class="card"><h2>What’s included</h2><div class="grid"><div class="mini"><b>Smart Daily 10</b><br>Sentence prompts, manual next, hint = verb only, full review at the end.</div><div class="mini"><b>Spaced repetition</b><br>Correct answers come back later. Missed verbs come back sooner.</div><div class="mini"><b>Mexican everyday phrases</b><br>Common sentences like “¿Ya comiste?”, “Pásale”, “No sé”, “Ahorita voy”.</div><div class="mini"><b>Audio</b><br>Uses your browser’s Spanish voice and prefers es-MX when available.</div></div></section>`;}
function startDaily(){daily=chooseDaily(); dailyIdx=0; dailyResults=[]; renderDaily();}
function renderDaily(){if(dailyIdx>=daily.length)return finishDaily(); current=daily[dailyIdx]; const pct=Math.round((dailyIdx/daily.length)*100); $('main').innerHTML=`<section class="card"><div class="progress"><div class="bar" style="width:${pct}%"></div></div><p class="muted">Question ${dailyIdx+1}/10</p><p class="tag">Translate this everyday sentence into Spanish</p><div class="sentence">${current.prompt}</div><p><button class="light" onclick="showHint()">Hint</button> <span id="hint" class="pill hidden"></span></p><input id="answer" placeholder="Type the whole sentence in Spanish..." onkeydown="if(event.key==='Enter')checkDaily()" autofocus>${accentButtons('answer')}<div id="feedback" class="feedback"></div><div class="row"><button onclick="checkDaily()">Check Answer</button><button id="nextBtn" class="secondary" onclick="nextDaily()" disabled>Next Question</button><button class="light" onclick="speak(current.answer)">🔊 Hear correct sentence</button></div><p class="small muted">Hint shows only the verb: not the answer. The answer stays on screen until you click Next.</p></section>`; $('answer').focus();}
function showHint(){$('hint').textContent=current.hint; $('hint').classList.remove('hidden');}
function checkDaily(){const ans=$('answer').value; const ok=isCorrect(ans,current.answer); $('feedback').innerHTML= ok?`✅ Correct!<div class="mini"><b>${current.answer}</b></div>`:`❌ Not quite.<div class="mini">Correct: <b>${current.answer}</b><br><span class="muted">Target verb: ${current.verb}</span></div>`; speak(current.answer); dailyResults[dailyIdx]={...current,your:ans||'(blank)',ok}; updateVerb(current.verb,ok); $('nextBtn').disabled=false;}
function nextDaily(){if(!dailyResults[dailyIdx])checkDaily(); dailyIdx++; renderDaily();}
function finishDaily(){const correct=dailyResults.filter(x=>x.ok).length; if(store.lastDaily!==todayKey()){store.streak++; store.lastDaily=todayKey();} store.sessions++; store.history.unshift({date:new Date().toLocaleString(),correct,total:10}); store.history=store.history.slice(0,30); save(); $('main').innerHTML=`<section class="card"><h2>🎉 Daily 10 complete</h2><p class="big">${correct}/10</p><p>Your answers are below. Missed verbs will show up sooner in future Daily 10 rounds.</p><table class="table"><thead><tr><th>#</th><th>Prompt</th><th>Your answer</th><th>Correct answer</th><th>Audio</th></tr></thead><tbody>${dailyResults.map((r,i)=>`<tr><td>${i+1}</td><td>${r.prompt}<br><span class="pill">verb: ${r.verb}</span></td><td class="${r.ok?'goodtext':'badtext'}">${r.your}</td><td><b>${r.answer}</b></td><td><button class="light" onclick="speak('${r.answer.replace(/'/g,"\\'")}')">🔊</button></td></tr>`).join('')}</tbody></table><button onclick="startDaily()">Play another Daily 10</button><button class="light" onclick="go('home')">Home</button></section>`;}
function renderFlash(){const pool=shuffle(verbs).sort((a,b)=>dueScore(b)-dueScore(a)); let v=pool[0]; const pair=shuffle(v.sentences)[0]; current={...v,prompt:pair[0],answer:pair[1]}; $('main').innerHTML=`<section class="card"><p class="tag">Flashcard</p><div class="big">${v.sp}</div><p class="muted">${v.en}</p><div id="reveal" class="hidden"><div class="sentence"><b>${pair[1]}</b><br>${pair[0]}</div></div><div class="row"><button onclick="$('reveal').classList.remove('hidden'); speak('${pair[1].replace(/'/g,"\\'")}')">Reveal + Audio</button><button class="good" onclick="updateVerb('${v.sp}',true); renderFlash()">I knew it</button><button class="bad" onclick="updateVerb('${v.sp}',false); renderFlash()">Again</button></div></section>`;}
function renderSituation(){const v=shuffle(verbs)[0], pair=shuffle(v.sentences)[0]; current={...v,prompt:pair[0],answer:pair[1]}; $('main').innerHTML=`<section class="card"><p class="tag">Situation Game</p><div class="sentence">You are in a real-life conversation. Say this naturally in Mexican Spanish:<br><br><b>${pair[0]}</b></div><p><button class="light" onclick="showSitHint('${v.sp}')">Hint</button> <span id="hint" class="pill hidden"></span></p><input id="sitAnswer" placeholder="Type what you would say..." onkeydown="if(event.key==='Enter')checkSituation()" autofocus>${accentButtons('sitAnswer')}<div id="sitFb" class="feedback"></div><div class="row"><button onclick="checkSituation()">Check</button><button class="secondary" onclick="renderSituation()">New situation</button></div></section>`; $('sitAnswer').focus();}
function showSitHint(v){$('hint').textContent=v; $('hint').classList.remove('hidden');}
function checkSituation(){const ans=$('sitAnswer').value; const ok=isCorrect(ans,current.answer); updateVerb(current.sp,ok); $('sitFb').innerHTML=`${ok?'✅ Nice!':'✨ Good practice — natural answer:'}<div class="mini"><b>${current.answer}</b><br><span class="muted">${current.prompt}</span></div>`; speak(current.answer);}
let chatTopic='Tacos / food', chatStep=0, chatScript=[];
function renderChatSetup(){const opts=Object.keys(topics).map(t=>`<option>${t}</option>`).join(''); $('main').innerHTML=`<section class="card"><h2>💬 Practice Chat</h2><p>This is a free offline conversation trainer. It is not connected to AI, but it gives you real back-and-forth practice using the words you’re learning.</p><select id="topic">${opts}</select><button onclick="startChat()">Start</button><div class="mini"><b>Goal:</b> answer in short Spanish sentences. Use the suggestion only if you get stuck.</div></section>`;}
function makeChat(topic){const s={
'Tacos / food':[['¡Hola! ¿Ya comiste?','Sí, ya comí. / No, todavía no.'],['¿Qué quieres pedir?','Quiero pedir tacos.'],['¿Qué vas a tomar?','Voy a tomar agua.'],['¿Pagas tú o pago yo?','Yo pago esta vez.'],['Sale, ¡provecho!','Gracias.']],
'At home':[['¿Qué haces en la casa?','Estoy limpiando.'],['¿Ya lavaste los platos?','Sí, ya los lavé.'],['¿Alguien está timbrando?','Sí, alguien está timbrando.'],['¿Quieres descansar?','Sí, quiero descansar un rato.'],['Bueno, descansa.','Gracias.']],
'Errands':[['¿A dónde vas?','Voy al súper.'],['¿Qué vas a comprar?','Voy a comprar leche.'],['¿Trajiste las llaves?','Sí, traje las llaves.'],['¿Puedes recoger la comida?','Sí, puedo recogerla.'],['Avísame cuando llegues.','Sí, ya llegué.']],
'Relationship / feelings':[['¿Cómo te sientes hoy?','Me siento cansada.'],['¿Quieres hablar?','Sí, quiero hablar.'],['No quiero pelear.','Yo tampoco quiero pelear.'],['¿Qué piensas?','Pienso que sí.'],['Me hiciste reír.','Qué bueno.']],
'Travel / plans':[['¿Estás planeando un viaje?','Sí, estoy planeando un viaje.'],['¿A quién vas a visitar?','Voy a visitar a mi familia.'],['¿Vas a volar o manejar?','Voy a volar.'],['¿Cuándo regresas?','Regreso el lunes.'],['¡Buen viaje!','Gracias.']],
'Pets / baby':[['¿Quieres adoptar o acoger un perrito?','Queremos adoptar un perro.'],['¿Vas a bañar al perro?','Sí, voy a bañarlo.'],['¿Quién va a recoger la comida?','Yo voy a recoger la comida.'],['El bebé está llorando.','Voy a cuidar al bebé.'],['Qué bonito.','Sí, lo quiero mucho.']]
}; return s[topic]||s['Tacos / food'];}
function startChat(){chatTopic=$('topic').value; chatStep=0; chatScript=makeChat(chatTopic); $('main').innerHTML=`<section class="card"><h2>💬 ${chatTopic}</h2><div id="chatbox" class="chatbox"></div><p class="small muted">Suggestion: <span id="suggestion"></span></p><textarea id="chatInput" placeholder="Reply in Spanish..."></textarea>${accentButtons('chatInput')}<div class="row"><button onclick="sendChat()">Send</button><button class="light" onclick="speak(lastSpanish)">🔊 Replay</button><button class="secondary" onclick="renderChatSetup()">Change topic</button></div></section>`; botSay(chatScript[0][0]);}
function addMsg(text,who){const box=$('chatbox'); const div=document.createElement('div'); div.className='msg '+(who==='me'?'me':'bot'); div.textContent=text; box.appendChild(div); box.scrollTop=box.scrollHeight; if(who==='bot')speak(text);}
function botSay(text){addMsg(text,'bot'); $('suggestion').textContent=chatScript[chatStep]?.[1]||'Answer naturally in Spanish.';}
function sendChat(){const input=$('chatInput'), text=input.value.trim(); if(!text)return; addMsg(text,'me'); input.value=''; chatStep++; if(chatStep<chatScript.length)setTimeout(()=>botSay(chatScript[chatStep][0]),300); else setTimeout(()=>addMsg('¡Muy bien! Terminaste la conversación. 🎉','bot'),300);}
function renderBank(){const tabs=['All','Due','Mastered','Needs practice']; const rows=verbs.map(v=>{const s=stat(v), m=mastery(v), due=Date.now()>s.next; const pair=v.sentences[0]; return `<tr data-master="${m}" data-due="${due}" data-wrong="${s.wrong}"><td><b>${v.sp}</b><br><span class="muted">${v.en}</span><br><span class="pill">mastery ${m}/5</span>${due?'<span class="pill">due</span>':''}</td><td>${pair[1]}<br><span class="muted">${pair[0]}</span></td><td>Seen ${s.seen}<br>Correct ${s.correct}<br>Wrong ${s.wrong}</td><td><button class="light" onclick="speak('${pair[1].replace(/'/g,"\\'")}')">🔊</button></td></tr>`}).join(''); $('main').innerHTML=`<section class="card"><h2>📚 Word Bank (${verbs.length})</h2><p class="muted">Includes your full verb bank plus a few ultra-common everyday verbs. I corrected typos in display where needed, while keeping your intended words: agarrar, sorprender, llover, oír, caer.</p><div class="tabs">${tabs.map(t=>`<button onclick="filterBank('${t}')">${t}</button>`).join('')}</div><table class="table" id="bankTable"><thead><tr><th>Verb</th><th>Common sentence</th><th>Progress</th><th>Audio</th></tr></thead><tbody>${rows}</tbody></table><div class="card dangerzone"><h3>Reset progress</h3><p class="small muted">This only clears progress in this browser.</p><button class="bad" onclick="if(confirm('Reset all progress?')){localStorage.removeItem('verbQuestMX'); location.reload()} ">Reset</button></div></section>`;}
function filterBank(kind){document.querySelectorAll('#bankTable tbody tr').forEach(tr=>{const m=+tr.dataset.master, due=tr.dataset.due==='true', wrong=+tr.dataset.wrong; let show=kind==='All'||(kind==='Due'&&due)||(kind==='Mastered'&&m>=4)||(kind==='Needs practice'&&(wrong>0||m<2)); tr.style.display=show?'':'none';});}
renderHome();
</script>
</body>
